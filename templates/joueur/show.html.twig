{% extends 'base.html.twig' %}

{% block title %}Fiche joueur{% endblock %}

{% block body %}
<section class="player-page">

    <h1>Fiche joueur</h1>

    <div class="player-card">

        <div class="player-header">
            <div class="avatar">
                {{ joueur.prenom|first|upper }}{{ joueur.nom|first|upper }}
            </div>

            <div>
                <h2>{{ joueur.prenom }} {{ joueur.nom }}</h2>

                {% if joueur.suspendu %}
                    <span class="badge-red">🚫 Suspendu</span>
                {% else %}
                    <span class="badge-green">{{ joueur.statut }}</span>
                {% endif %}
            </div>
        </div>

        <div class="player-grid">
            <p>📅 <strong>Naissance :</strong> {{ joueur.dateNaissance|date('d/m/Y') }}</p>
            <p>👤 <strong>Genre :</strong> {{ joueur.genre }}</p>
            <p>⚽ <strong>Poste :</strong> {{ joueur.postePrefere }}</p>
            <p>🏟 <strong>Équipe :</strong> {{ joueur.equipe.nomEquipe }}</p>
            <p>🧑‍🏫 <strong>Responsable :</strong> {{ joueur.responsable.nom }} {{ joueur.responsable.prenom }}</p>
            <p>🩺 <strong>Médecin :</strong> {{ joueur.docteurNom }}</p>
            <p>📞 <strong>Téléphone :</strong> {{ joueur.docteurPhone }}</p>
        </div>

        <div class="player-cartons">
            <h3>Cartons</h3>

            <div class="carton-box">
                <span class="yellow">🟨 {{ joueur.nombreCartonsJaunes }}</span>
                <span class="red">🟥 {{ joueur.nombreCartonsRouges }}</span>
            </div>
        </div>

    </div>

    <div class="panel">
        <h3>Historique des cartons</h3>

        {% if joueur.cartons|length > 0 %}
            <ul class="timeline">
                {% for carton in joueur.cartons|sort((a, b) => b.dateCarton <=> a.dateCarton) %}
                    <li>
                        <div class="timeline-dot 
                            {% if carton.couleurCarton == 'jaune' %}yellow{% else %}red{% endif %}">
                        </div>

                        <div class="timeline-content">
                            <strong>{{ carton.dateCarton|date('d/m/Y') }}</strong>

                            {% if carton.couleurCarton == 'jaune' %}
                                🟨 Carton jaune
                            {% else %}
                                🟥 Carton rouge
                            {% endif %}

                            — {{ carton.motif ?: 'Pas de motif' }}

                            {% if carton.rencontre %}
                                <br>
                                <span class="match-info">
                                    vs {{ carton.rencontre.adversaire ?: 'Adversaire non renseigné' }}

                                    {% if carton.rencontre.dateMatch %}
                                        ({{ carton.rencontre.dateMatch|date('d/m/Y') }})
                                    {% endif %}
                                </span>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>Aucun carton pour ce joueur.</p>
        {% endif %}
    </div>

    <div class="page-actions">
        <a href="{{ path('app_joueur_index') }}" class="profile-btn">Retour à la liste</a>
        <a href="{{ path('app_joueur_edit', {'id': joueur.id}) }}" class="profile-btn">Modifier</a>
    </div>

    {{ include('joueur/_delete_form.html.twig') }}

</section>
{% endblock %}