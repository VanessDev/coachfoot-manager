{% extends 'base.html.twig' %}

{% block title %}Responsable{% endblock %}

{% block body %}
    <h1>Responsable</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ responsable.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ responsable.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ responsable.prenom }}</td>
            </tr>
            <tr>
                <th>Telephone</th>
                <td>{{ responsable.telephone }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ responsable.email }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ responsable.adresse }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_responsable_index') }}">back to list</a>

    <a href="{{ path('app_responsable_edit', {'id': responsable.id}) }}">edit</a>

    {{ include('responsable/_delete_form.html.twig') }}
{% endblock %}
