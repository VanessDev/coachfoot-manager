{{ form_start(form, {'attr': {'class': 'app-form'}}) }}

    <div class="form-group">
        {{ form_label(form.couleurCarton, 'Couleur du carton') }}
        {{ form_widget(form.couleurCarton) }}
    </div>

    <div class="form-group">
        {{ form_label(form.dateCarton, 'Date du carton') }}
        {{ form_widget(form.dateCarton) }}
    </div>

    <div class="form-group">
        {{ form_label(form.motif, 'Motif') }}
        {{ form_widget(form.motif) }}
    </div>

    <div class="form-group">
        {{ form_label(form.joueur, 'Joueur') }}
        {{ form_widget(form.joueur) }}
    </div>

    <div class="form-group">
        {{ form_label(form.rencontre, 'Rencontre') }}
        {{ form_widget(form.rencontre) }}
    </div>

    <button class="btn-create">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}