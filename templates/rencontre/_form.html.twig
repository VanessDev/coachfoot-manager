{{ form_start(form, {'attr': {'class': 'app-form'}}) }}

    <div class="form-group">
        {{ form_label(form.dateMatch, 'Date match') }}
        {{ form_widget(form.dateMatch) }}
    </div>

    <div class="form-group">
        {{ form_label(form.heureMatch, 'Heure match') }}
        {{ form_widget(form.heureMatch) }}
    </div>

    <div class="form-group">
        {{ form_label(form.lieu, 'Lieu') }}
        {{ form_widget(form.lieu) }}
    </div>

    <div class="form-group">
        {{ form_label(form.adversaire, 'Adversaire') }}
        {{ form_widget(form.adversaire) }}
    </div>

    <div class="form-group">
        {{ form_label(form.typeMatch, 'Type match') }}
        {{ form_widget(form.typeMatch) }}
    </div>

    <div class="form-group">
        {{ form_label(form.scoreEquipe, 'Score équipe') }}
        {{ form_widget(form.scoreEquipe) }}
    </div>

    <div class="form-group">
        {{ form_label(form.scoreAdversaire, 'Score adversaire') }}
        {{ form_widget(form.scoreAdversaire) }}
    </div>

    <div class="form-group">
        {{ form_label(form.resume, 'Résumé') }}
        {{ form_widget(form.resume) }}
    </div>

    <div class="form-group">
        {{ form_label(form.equipe, 'Équipe') }}
        {{ form_widget(form.equipe) }}
    </div>

    <button class="btn-create">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}