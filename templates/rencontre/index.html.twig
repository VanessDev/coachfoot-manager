{% extends 'base.html.twig' %}

{% block title %}Rencontre index{% endblock %}

{% block body %}
    <h1>Rencontre index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>DateMatch</th>
                <th>HeureMatch</th>
                <th>Lieu</th>
                <th>Adversaire</th>
                <th>TypeMatch</th>
                <th>ScoreEquipe</th>
                <th>ScoreAdversaire</th>
                <th>Resume</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for rencontre in rencontres %}
            <tr>
                <td>{{ rencontre.id }}</td>
                <td>{{ rencontre.dateMatch ? rencontre.dateMatch|date('Y-m-d') : '' }}</td>
                <td>{{ rencontre.heureMatch ? rencontre.heureMatch|date('H:i:s') : '' }}</td>
                <td>{{ rencontre.lieu }}</td>
                <td>{{ rencontre.adversaire }}</td>
                <td>{{ rencontre.typeMatch }}</td>
                <td>{{ rencontre.scoreEquipe }}</td>
                <td>{{ rencontre.scoreAdversaire }}</td>
                <td>{{ rencontre.resume }}</td>
                <td>
                    <a href="{{ path('app_rencontre_show', {'id': rencontre.id}) }}">show</a>
                    <a href="{{ path('app_rencontre_edit', {'id': rencontre.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_rencontre_new') }}" class="btn-create">
    ➕ Nouvelle rencontre
</a>
{% endblock %}
