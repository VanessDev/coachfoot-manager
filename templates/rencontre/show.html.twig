{% extends 'base.html.twig' %}

{% block title %}Rencontre{% endblock %}

{% block body %}
    <h1>Rencontre</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ rencontre.id }}</td>
            </tr>
            <tr>
                <th>DateMatch</th>
                <td>{{ rencontre.dateMatch ? rencontre.dateMatch|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>HeureMatch</th>
                <td>{{ rencontre.heureMatch ? rencontre.heureMatch|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Lieu</th>
                <td>{{ rencontre.lieu }}</td>
            </tr>
            <tr>
                <th>Adversaire</th>
                <td>{{ rencontre.adversaire }}</td>
            </tr>
            <tr>
                <th>TypeMatch</th>
                <td>{{ rencontre.typeMatch }}</td>
            </tr>
            <tr>
                <th>ScoreEquipe</th>
                <td>{{ rencontre.scoreEquipe }}</td>
            </tr>
            <tr>
                <th>ScoreAdversaire</th>
                <td>{{ rencontre.scoreAdversaire }}</td>
            </tr>
            <tr>
                <th>Resume</th>
                <td>{{ rencontre.resume }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_rencontre_index') }}">back to list</a>

    <a href="{{ path('app_rencontre_edit', {'id': rencontre.id}) }}">edit</a>

    {{ include('rencontre/_delete_form.html.twig') }}
{% endblock %}
