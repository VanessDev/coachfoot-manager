{% extends 'base.html.twig' %}

{% block title %}Entrainement{% endblock %}

{% block body %}
    <h1>Entrainement</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ entrainement.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ entrainement.titre }}</td>
            </tr>
            <tr>
                <th>DateEntrainement</th>
                <td>{{ entrainement.dateEntrainement ? entrainement.dateEntrainement|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>HeureDebut</th>
                <td>{{ entrainement.heureDebut ? entrainement.heureDebut|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>HeureFin</th>
                <td>{{ entrainement.heureFin ? entrainement.heureFin|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Lieu</th>
                <td>{{ entrainement.lieu }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_entrainement_index') }}">back to list</a>

    <a href="{{ path('app_entrainement_edit', {'id': entrainement.id}) }}">edit</a>

    {{ include('entrainement/_delete_form.html.twig') }}
{% endblock %}
